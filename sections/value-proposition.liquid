<section class="section-spacing" id="technology" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="value-prop__header reveal">
      {%- if section.settings.badge_text != blank -%}
        <div style="margin-bottom:16px">
          <span class="badge">{{ section.settings.badge_text }}</span>
        </div>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p style="margin-top:16px;margin-inline:auto">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="value-prop__grid reveal-children">
      {%- for block in section.blocks -%}
        <div class="card value-card" {{ block.shopify_attributes }}>
          <div class="value-card__icon">
            {%- case block.settings.icon -%}
              {%- when 'heart' -%}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              {%- when 'moon' -%}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
              {%- when 'activity' -%}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
              {%- when 'battery' -%}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="1" y="6" width="18" height="12" rx="2" ry="2"/><line x1="23" y1="13" x2="23" y2="11"/>
                </svg>
              {%- when 'droplet' -%}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
                </svg>
              {%- when 'shield' -%}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              {%- else -%}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="10"/>
                </svg>
            {%- endcase -%}
          </div>
          <h3 class="value-card__title">{{ block.settings.title }}</h3>
          <p class="value-card__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value Proposition",
  "tag": "section",
  "class": "value-prop-section",
  "settings": [
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Why AURARING" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Designed for the modern human" },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The most advanced health sensors, engineered into the most minimal form factor."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Value card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "heart",
          "options": [
            { "value": "heart", "label": "Heart" },
            { "value": "moon", "label": "Moon / Sleep" },
            { "value": "activity", "label": "Activity" },
            { "value": "battery", "label": "Battery" },
            { "value": "droplet", "label": "Droplet / SpO2" },
            { "value": "shield", "label": "Shield" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Feature Title" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Feature description goes here." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Value Proposition",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon": "heart",
            "title": "Heart Rate Monitoring",
            "text": "Continuous 24/7 heart rate tracking with clinical-grade PPG sensors and real-time alerts."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "moon",
            "title": "Advanced Sleep Analysis",
            "text": "Detailed sleep staging, quality scores, and circadian rhythm insights every morning."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "activity",
            "title": "Activity Intelligence",
            "text": "Steps, calories, and active minutes — without a bulky wristband weighing you down."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "battery",
            "title": "7-Day Battery Life",
            "text": "Up to 7 days on a single charge. Full charge in under 80 minutes. No charging anxiety."
          }
        }
      ]
    }
  ]
}
{% endschema %}
