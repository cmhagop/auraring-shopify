<section class="section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="cta-banner reveal">
      <div class="cta-banner__glow"></div>
      <div class="cta-banner__content">
        <h2 class="cta-banner__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="cta-banner__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.button_text != blank -%}
          {%- assign btn_url = section.settings.button_product.url | default: section.settings.button_link -%}
          {%- render 'button', label: section.settings.button_text, url: btn_url, style: 'accent', size: 'lg' -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "tag": "section",
  "class": "cta-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to know yourself better?" },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join thousands who have made AURARING part of their daily ritual."
    },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop AURARING" },
    { "type": "product", "id": "button_product", "label": "Button product" },
    { "type": "url", "id": "button_link", "label": "Button link (fallback)", "default": "" }
  ],
  "presets": [{ "name": "Final CTA" }]
}
{% endschema %}
