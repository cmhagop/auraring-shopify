<section class="cinematic-banner section-spacing" data-section-id="{{ section.id }}">
  {%- comment -%} === Video / Image media layer === {%- endcomment -%}
  <div class="cinematic-banner__media">
    {%- if section.settings.video != blank -%}
      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          playsinline: true,
          controls: false,
          class: 'cinematic-banner__video'
      }}
    {%- elsif section.settings.video_url != blank -%}
      {%- if section.settings.video_url.type == 'youtube' -%}
        <iframe
          src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ section.settings.video_url.id }}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
          class="cinematic-banner__video cinematic-banner__video--iframe"
          allow="autoplay; encrypted-media"
          allowfullscreen
          loading="lazy"
          title="{{ section.settings.heading | escape }}"
        ></iframe>
      {%- elsif section.settings.video_url.type == 'vimeo' -%}
        <iframe
          src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1&muted=1&loop=1&background=1&playsinline=1"
          class="cinematic-banner__video cinematic-banner__video--iframe"
          allow="autoplay; encrypted-media"
          allowfullscreen
          loading="lazy"
          title="{{ section.settings.heading | escape }}"
        ></iframe>
      {%- endif -%}
    {%- elsif section.settings.fallback_image != blank -%}
      <img
        src="{{ section.settings.fallback_image | image_url: width: 1920 }}"
        alt="{{ section.settings.heading | escape }}"
        class="cinematic-banner__video"
        loading="lazy"
      >
    {%- else -%}
      <img
        src="{{ 'hero-banner.png' | asset_url }}"
        alt="{{ section.settings.heading | escape }}"
        class="cinematic-banner__video"
        loading="lazy"
      >
    {%- endif -%}

    {%- comment -%} === Edge-fade overlays === {%- endcomment -%}
    <div class="cinematic-banner__fade cinematic-banner__fade--top"></div>
    <div class="cinematic-banner__fade cinematic-banner__fade--bottom"></div>
    <div class="cinematic-banner__fade cinematic-banner__fade--left"></div>
    <div class="cinematic-banner__fade cinematic-banner__fade--right"></div>
  </div>

  {%- comment -%} === Content overlay === {%- endcomment -%}
  <div class="cinematic-banner__content">
    <div class="page-width">
      {%- if section.settings.badge_text != blank -%}
        <div class="cinematic-banner__badge">
          <span class="badge">{{ section.settings.badge_text }}</span>
        </div>
      {%- endif -%}

      <h2 class="cinematic-banner__heading">{{ section.settings.heading }}</h2>

      {%- if section.settings.subheading != blank -%}
        <p class="cinematic-banner__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        {%- assign btn_url = section.settings.button_product.url | default: section.settings.button_link -%}
        <div class="cinematic-banner__cta">
          {%- render 'button', label: section.settings.button_text, url: btn_url, style: 'accent', size: 'lg' -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  /* ================================================================
     CINEMATIC BANNER — Cinematic single-product video section
     ================================================================ */
  .cinematic-banner {
    position: relative;
    width: 100%;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 0;
    background-color: var(--color-bg, #000);
  }

  /* --- Media layer ------------------------------------------------ */
  .cinematic-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .cinematic-banner__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .cinematic-banner__video--iframe {
    border: 0;
    pointer-events: none;
    /* Scale the iframe up to avoid letterboxing */
    position: absolute;
    top: 50%;
    left: 50%;
    width: 120%;
    height: 120%;
    transform: translate(-50%, -50%);
  }

  /* --- Edge-fade gradient overlays -------------------------------- */
  .cinematic-banner__fade {
    position: absolute;
    z-index: 1;
    pointer-events: none;
  }

  .cinematic-banner__fade--top {
    top: 0;
    left: 0;
    right: 0;
    height: 30%;
    background: linear-gradient(180deg, var(--color-bg) 0%, rgba(10, 10, 10, 0.7) 40%, transparent 100%);
  }

  .cinematic-banner__fade--bottom {
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(0deg, var(--color-bg) 0%, rgba(10, 10, 10, 0.75) 35%, transparent 100%);
  }

  .cinematic-banner__fade--left {
    top: 0;
    bottom: 0;
    left: 0;
    width: 15%;
    background: linear-gradient(90deg, var(--color-bg) 0%, transparent 100%);
  }

  .cinematic-banner__fade--right {
    top: 0;
    bottom: 0;
    right: 0;
    width: 15%;
    background: linear-gradient(270deg, var(--color-bg) 0%, transparent 100%);
  }

  /* --- Content overlay -------------------------------------------- */
  .cinematic-banner__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 80px 20px;
    width: 100%;
  }

  .cinematic-banner__badge {
    margin-bottom: 24px;
  }

  .cinematic-banner__heading {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-text);
    text-shadow: 0 4px 60px rgba(0, 0, 0, 0.5);
    margin-bottom: 20px;
  }

  .cinematic-banner__subheading {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: rgba(240, 240, 240, 0.65);
    line-height: 1.7;
    max-width: 520px;
    margin-inline: auto;
    margin-bottom: 40px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
  }

  .cinematic-banner__cta {
    margin-top: 8px;
  }

  /* --- Responsive ------------------------------------------------- */
  @media (max-width: 749px) {
    .cinematic-banner {
      min-height: 70vh;
    }

    .cinematic-banner__content {
      padding: 60px 16px;
    }

    .cinematic-banner__fade--top {
      height: 25%;
    }

    .cinematic-banner__fade--bottom {
      height: 35%;
    }

    .cinematic-banner__fade--left,
    .cinematic-banner__fade--right {
      width: 8%;
    }

    .cinematic-banner__heading {
      font-size: clamp(2rem, 10vw, 3.2rem);
    }
  }
</style>

{% schema %}
{
  "name": "Cinematic Product Banner",
  "tag": "section",
  "class": "cinematic-banner-section",
  "settings": [
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Featured" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Auraring Tungsten" },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Forged from aerospace-grade tungsten carbide. Indestructible. Timeless. Unmistakably premium."
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify Video",
      "info": "Upload a video in Settings > Files, then select it here. It will autoplay muted and loop."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "YouTube / Vimeo URL (fallback)",
      "accept": ["youtube", "vimeo"],
      "info": "Used only if no Shopify-hosted video is selected above."
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback image",
      "info": "Shown if no video is available. Also acts as a poster frame."
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop Tungsten" },
    { "type": "product", "id": "button_product", "label": "Button product" },
    { "type": "url", "id": "button_link", "label": "Button link (fallback)", "default": "" }
  ],
  "presets": [
    {
      "name": "Cinematic Product Banner"
    }
  ]
}
{% endschema %}
