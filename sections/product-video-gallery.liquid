<section class="product-video-gallery section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank or section.settings.subtext != blank -%}
      <div class="video-gallery__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="video-gallery__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}
          <p class="video-gallery__subtext">{{ section.settings.subtext }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="video-gallery__grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="video-gallery__item" {{ block.shopify_attributes }}>
            <div class="video-gallery__media">
              {%- if block.settings.video != blank -%}
                {{
                  block.settings.video
                  | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '600x'
                }}
              {%- else -%}
                <div
                  class="education__media-placeholder"
                  style="aspect-ratio: 16/9; height: auto; min-height: unset;"
                >
                  No Video Selected
                </div>
              {%- endif -%}
            </div>
            {%- if block.settings.heading != blank or block.settings.caption != blank -%}
              <div class="video-gallery__content" style="margin-top: 16px; text-align: center;">
                {%- if block.settings.heading != blank -%}
                  <h3 class="video-gallery__item-title" style="font-size: 1.1rem; margin-bottom: 8px;">
                    {{ block.settings.heading }}
                  </h3>
                {%- endif -%}
                {%- if block.settings.caption != blank -%}
                  <p class="video-gallery__item-caption" style="font-size: 0.9rem; color: var(--color-text-muted);">
                    {{ block.settings.caption }}
                  </p>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} DIAGNOSTIC FALLBACK: 3 visible placeholders {%- endcomment -%}
        {%- for i in (1..3) -%}
          <div class="video-gallery__item">
            <div class="education__media-placeholder" style="aspect-ratio: 16/9; height: auto; min-height: unset;">
              Video Placeholder {{ i }}
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video Gallery",
  "tag": "section",
  "class": "section-video-gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See it in action."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "SubheadingText",
      "default": "A closer look at the precision engineering and elegant design."
    }
  ],
  "blocks": [
    {
      "type": "video_slot",
      "name": "Video Slot",
      "limit": 3,
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-hosted Video"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Feature Insight"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "A deep dive into how this feature improves your daily readiness score."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Gallery",
      "blocks": [{ "type": "video_slot" }, { "type": "video_slot" }, { "type": "video_slot" }]
    }
  ]
}
{% endschema %}
