<section class="product-page section-spacing" data-section-id="{{ section.id }}">
  <div
    class="product-page__ambient-layer"
    aria-hidden="true"
    style="{% if section.settings.ambient_bg %}background-image: url('{{ section.settings.ambient_bg | image_url: width: 1500 }}');{% else %}background-image: url('{{ 'product-ambient-bg.png' | asset_url }}');{% endif %}"
  ></div>
  <div class="page-width">
    <div class="product-page__inner">
      {%- comment -%} Gallery (55% Split) {%- endcomment -%}
      <div class="product-page__gallery">
        {%- if product.images.size > 1 -%}
          <div class="product-page__gallery-thumbs">
            {%- for image in product.images -%}
              <div class="product-page__gallery-thumb{% if forloop.first %} is-active{% endif %}">
                <img
                  src="{{ image | image_url: width: 200 }}"
                  alt="{{ image.alt | escape }}"
                  width="200"
                  loading="lazy"
                >
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div class="product-page__gallery-main">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 1200 }}"
              alt="{{ product.featured_image.alt | escape }}"
              width="1200"
              id="ProductMainImage"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag }}
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Product Info {%- endcomment -%}
      <div class="product-page__info">
        <div class="product-page__title-wrap">
          {%- if product.vendor -%}
            <div class="product-page__vendor">{{ product.vendor }}</div>
          {%- endif -%}
          <h1 class="product-page__title">{{ product.title }}</h1>
        </div>

        <div class="product-page__price">
          <span class="product-page__price-current">
            {{- product.selected_or_first_available_variant.price | money -}}
          </span>
          {%- if product.selected_or_first_available_variant.compare_at_price
              > product.selected_or_first_available_variant.price
          -%}
            <span class="product-page__price-compare">
              {{ product.selected_or_first_available_variant.compare_at_price | money }}
            </span>
          {%- endif -%}
        </div>

        {%- if section.settings.show_quick_benefits -%}
          <ul class="product-page__quick-benefits">
            <li>Clinical-grade precision sensors</li>
            <li>Up to 7 days battery life</li>
            <li>Ultra-lightweight aerospace titanium</li>
          </ul>
        {%- endif -%}

        {%- if product.description != blank -%}
          <div class="product-page__description">{{ product.description | truncatewords: 24 }}</div>
        {%- endif -%}

        {%- comment -%} Variants {%- endcomment -%}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="product-page__variants">
              <div class="product-page__variant-label">{{ option.name }}</div>
              <div class="product-page__variant-options">
                {%- for value in option.values -%}
                  <button
                    class="product-page__variant-btn{% if option.selected_value == value %} is-active{% endif %}"
                    data-option-name="{{ option.name }}"
                    data-option-value="{{ value }}"
                  >
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        {%- comment -%} Add to Cart {%- endcomment -%}
        <div class="product-page__buy-box">
          <form method="post" action="/cart/add" accept-charset="UTF-8" enctype="multipart/form-data">
            <input type="hidden" name="form_type" value="product">
            <input type="hidden" name="utf8" value="✓">
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            {%-
              render 'button',
              label: 'Add to Cart',
              style: 'primary',
              size: 'lg',
              full: true,
              type: 'submit',
              disabled: product.selected_or_first_available_variant.available == false
            -%}
          </form>

          {%- if section.settings.show_trust_badges -%}
            <div class="product-page__trust-signals">
              <div class="trust-signal">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                <span>1-Year Warranty</span>
              </div>
              <div class="trust-signal">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle>
                </svg>
                <span>Free Insured Shipping</span>
              </div>
              <div class="trust-signal">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>30-Day Risk-Free Trial</span>
              </div>
            </div>
          {%- endif -%}
        </div>

        <hr class="glow-divider" style="margin-block:36px; opacity:0.5;">

        {%- comment -%} Collapsible tabs {%- endcomment -%}
        {%- for block in section.blocks -%}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button class="faq-item__trigger" aria-expanded="false">
              <span>{{ block.settings.heading }}</span>
              <span class="faq-item__icon" aria-hidden="true"></span>
            </button>
            <div class="faq-item__content">
              <div class="faq-item__answer">{{ block.settings.content }}</div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Page",
  "tag": "section",
  "class": "product-page-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "ambient_bg",
      "label": "Ambient background layer",
      "info": "Heavy blur and opacity blend will be applied automatically."
    },
    {
      "type": "header",
      "content": "Credibility Signals"
    },
    {
      "type": "checkbox",
      "id": "show_quick_benefits",
      "label": "Show quick bullet benefits under price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges under Add to Cart",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "collapsible",
      "name": "Collapsible tab",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Details" },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Add details about your product here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Page",
      "blocks": [
        {
          "type": "collapsible",
          "settings": { "heading": "Description", "content": "<p>Detailed product information.</p>" }
        },
        {
          "type": "collapsible",
          "settings": { "heading": "Specifications", "content": "<p>Materials, dimensions, and technical details.</p>" }
        },
        {
          "type": "collapsible",
          "settings": { "heading": "Shipping & Returns", "content": "<p>Free shipping worldwide. 30-day returns.</p>" }
        }
      ]
    }
  ]
}
{% endschema %}
