<section class="section-spacing" id="showcase" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="showcase__header reveal">
      {%- if section.settings.badge_text != blank -%}
        <div style="margin-bottom:16px">
          <span class="badge">{{ section.settings.badge_text }}</span>
        </div>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p style="margin-top:16px;margin-inline:auto">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="showcase__grid reveal-children">
      {%- for block in section.blocks -%}
        {%- assign p = block.settings.product -%}
        {%- assign card_url = p.url -%}
        {%- assign card_title = block.settings.title -%}
        {%- assign card_price = block.settings.price -%}
        
        {%- if p != blank -%}
          {%- assign card_title = p.title -%}
          {%- assign card_price = p.price | money -%}
        {%- endif -%}

        <{% if card_url != blank %}a href="{{ card_url }}"{% else %}div{% endif %} class="product-card" {{ block.shopify_attributes }}>
          <div class="product-card__image">
            {%- if p != blank and p.featured_image != blank -%}
              <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ card_title | escape }}" width="600" height="600" loading="lazy">
            {%- elsif block.settings.image -%}
              <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ card_title | escape }}" width="600" height="600" loading="lazy">
            {%- else -%}
              <img src="{{ 'hero-ring.png' | asset_url }}" alt="{{ card_title | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          <div class="product-card__info">
            <h3 class="product-card__title">{{ card_title }}</h3>
            <div class="product-card__price">
              {%- if p != blank and p.compare_at_price > p.price -%}
                <s>{{ p.compare_at_price | money }}</s>
              {%- endif -%}
              {{ card_price }}
            </div>
          </div>
        </{% if card_url != blank %}a{% else %}div{% endif %}>
      {%- endfor -%}
    </div>

    {%- if section.settings.button_text != blank -%}
      <div class="showcase__cta reveal">
        {%- assign btn_url = section.settings.button_product.url | default: section.settings.button_link -%}
        {%- render 'button', label: section.settings.button_text, url: btn_url, style: 'secondary' -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product Showcase",
  "tag": "section",
  "class": "showcase-section",
  "settings": [
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "The Collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Meet AURARING" },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium wearable technology, refined to its purest form."
    },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "View All Products" },
    { "type": "product", "id": "button_product", "label": "Button product" },
    { "type": "url", "id": "button_link", "label": "Button link (fallback)", "default": "" }
  ],
  "blocks": [
    {
      "type": "product_placeholder",
      "name": "Product card",
      "settings": [
        { "type": "product", "id": "product", "label": "Select product" },
        { "type": "header", "content": "Fallback content", "info": "Used if no product is selected" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "AURARING" },
        { "type": "text", "id": "price", "label": "Price", "default": "$299.00" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Showcase",
      "blocks": [
        {
          "type": "product_placeholder",
          "settings": { "title": "Auraring Stealth", "price": "$299.00" }
        },
        {
          "type": "product_placeholder",
          "settings": { "title": "Auraring Onyx", "price": "$349.00" }
        },
        {
          "type": "product_placeholder",
          "settings": { "title": "Auraring Tungsten", "price": "$349.00" }
        }
      ]
    }
  ]
}
{% endschema %}
