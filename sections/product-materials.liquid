<section class="product-materials section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="materials__container{% if section.settings.image_position == 'right' %} materials__container--reverse{% endif %}">
      <div class="materials__media">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.image.alt | escape }}"
            width="800"
            height="auto"
            loading="lazy"
          >
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}

        {%- if section.settings.badge_text != blank -%}
          <div class="materials__floating-badge">{{ section.settings.badge_text }}</div>
        {%- endif -%}
      </div>

      <div class="materials__content">
        {%- if section.settings.subtitle != blank -%}
          <div class="materials__subtitle">{{ section.settings.subtitle }}</div>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="materials__title">{{ section.settings.title }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="materials__text">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="materials__list">
            {%- for block in section.blocks -%}
              <li {{ block.shopify_attributes }}>
                <span class="materials__list-dot"></span>
                <strong>{{ block.settings.heading }}</strong>
                <span>{{ block.settings.description }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Materials",
  "tag": "section",
  "class": "section-product-materials",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Primary Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Desktop Image Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Floating Image Badge",
      "default": "Aerospace Grade"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Uncompromising Engineering"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Built to disappear."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Forged from ultra-lightweight titanium and sleek tungsten. AURARING is designed to be worn 24/7, providing clinical-grade data without the bulk of a smartwatch.</p>"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Material Feature",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Bullet Heading",
          "default": "Hypoallergenic"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Bullet Description",
          "default": "Safe for sensitive skin."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Materials",
      "blocks": [
        {
          "type": "feature",
          "settings": { "heading": "Hypoallergenic:", "description": "Medical-grade inner molding." }
        },
        {
          "type": "feature",
          "settings": { "heading": "Water Resistance:", "description": "Up to 100 meters (10 ATM)." }
        },
        {
          "type": "feature",
          "settings": { "heading": "Weightless:", "description": "Lighter than a conventional wedding band." }
        }
      ]
    }
  ]
}
{% endschema %}
