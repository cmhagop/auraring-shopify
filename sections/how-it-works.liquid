<section class="section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="how-it-works__header reveal">
      {%- if section.settings.badge_text != blank -%}
        <div style="margin-bottom:16px">
          <span class="badge">{{ section.settings.badge_text }}</span>
        </div>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p style="margin-top:16px;margin-inline:auto">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="how-it-works__steps reveal-children">
      {%- for block in section.blocks -%}
        <div class="card step-card" {{ block.shopify_attributes }}>
          <div class="step-card__number">{{ forloop.index }}</div>
          <h3 class="step-card__title">{{ block.settings.title }}</h3>
          <p class="step-card__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "tag": "section",
  "class": "how-it-works-section",
  "settings": [
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Simple Setup" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How it works" },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "From unboxing to insight in three simple steps."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Step title" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Step description." }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Find your size",
            "text": "Use our free sizing kit to determine your perfect fit. Precision matters."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Wear it daily",
            "text": "Slip it on and forget it's there. AURARING works around the clock — silently."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Unlock your data",
            "text": "Open the app each morning for your Readiness Score, sleep analysis, and trends."
          }
        }
      ]
    }
  ]
}
{% endschema %}
