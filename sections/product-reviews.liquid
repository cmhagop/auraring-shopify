<section class="product-reviews section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="reviews__header">
        <h2 class="reviews__title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="reviews__grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="review-card" {{ block.shopify_attributes }}>
            <div class="review-card__stars">
              {%- for i in (1..5) -%}
                {%- if i <= block.settings.rating -%}
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- if block.settings.title != blank -%}
              <h3 class="review-card__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="review-card__text">{{ block.settings.text }}</div>
            {%- endif -%}

            <div class="review-card__author">{{ block.settings.author }}</div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} DIAGNOSTIC FALLBACK: 3 placeholder reviews {%- endcomment -%}
        {%- for i in (1..3) -%}
          <div class="review-card">
            <div class="review-card__stars" style="opacity: 0.3;">
              {%- for j in (1..5) -%}
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- endfor -%}
            </div>
            <h3 class="review-card__title">Placeholder Review {{ i }}</h3>
            <div class="review-card__text"><p>This is a diagnostic placeholder. Add a Review block in Customize to replace this content.</p></div>
            <div class="review-card__author">Verified Customer</div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Reviews",
  "tag": "section",
  "class": "section-product-reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What they're saying."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "limit": 6,
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star Rating",
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review Title",
          "default": "The only tracker I actually wear."
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Review Text",
          "default": "<p>I've tried smartwatches and bands, but they always got in the way. This ring is completely invisible to my daily routine, yet delivers the most accurate sleep data I've ever seen.</p>"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Reviewer Name",
          "default": "Alex R."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Reviews",
      "blocks": [
        { "type": "review" },
        {
          "type": "review",
          "settings": {
            "title": "Game-changer for recovery.",
            "text": "<p>The readiness score dictates my entire training schedule. It’s incredibly accurate and doesn’t look like a piece of plastic tech.</p>",
            "author": "Sarah L."
          }
        },
        {
          "type": "review",
          "settings": {
            "title": "Aesthetics meet data.",
            "text": "<p>Finally, a health tracker that actually looks like high-end jewelry. The 7-day battery life means I actually use it without constantly charging.</p>",
            "author": "David C."
          }
        }
      ]
    }
  ]
}
{% endschema %}
