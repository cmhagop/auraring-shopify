{%- comment -%}
  Technology Template Section
  Supports all technology page components via blocks.
{%- endcomment -%}

<div class="tech-page" data-section-id="{{ section.id }}">
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      
      {%- when 'tech_hero' -%}
        <section class="tech-hero" {{ block.shopify_attributes }}>
          <div class="tech-hero__bg">
            {%- if block.settings.background_video_hosted != blank -%}
              {{ block.settings.background_video_hosted | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, preload: 'auto', class: 'tech-hero__video' }}
            {%- elsif block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 2400 }}" alt="{{ block.settings.heading }}" loading="eager" class="tech-hero__image">
            {%- else -%}
              <div class="tech-hero__placeholder"></div>
            {%- endif -%}
            <div class="tech-hero__overlay"></div>
          </div>
          <div class="page-width">
            <div class="tech-hero__content">
              {%- if block.settings.badge != blank -%}
                <span class="tech-hero__badge">{{ block.settings.badge }}</span>
              {%- endif -%}
              <h1 class="tech-hero__heading">{{ block.settings.heading | default: "Inside AURARING" }}</h1>
              {%- if block.settings.subheading != blank -%}
                <p class="tech-hero__subheading">{{ block.settings.subheading }}</p>
              {%- endif -%}
            </div>
          </div>
        </section>

      {%- when 'intro' -%}
        <section class="tech-intro" {{ block.shopify_attributes }}>
          <div class="page-width">
            <div class="tech-intro__inner">
              <div class="tech-intro__text">
                {{ block.settings.content | default: "<p>We didn't just build a health tracker; we built a laboratory for your finger. By monitoring arterial pulse from the base of your finger, AURARING captures a signal 10x stronger than wrist-based wearables.</p>" }}
              </div>
            </div>
          </div>
        </section>

      {%- when 'feature_grid' -%}
        <section class="tech-features" {{ block.shopify_attributes }}>
          <div class="page-width">
            {%- if block.settings.heading != blank or block.settings.subheading != blank -%}
              <div class="tech-features__header">
                {%- if block.settings.heading != blank -%}<h2>{{ block.settings.heading }}</h2>{%- endif -%}
                {%- if block.settings.subheading != blank -%}<p>{{ block.settings.subheading }}</p>{%- endif -%}
              </div>
            {%- endif -%}
            
            <div class="tech-features__grid">
              {%- for i in (1..6) -%}
                {%- capture title_key -%}title_{{ i }}{%- endcapture -%}
                {%- capture text_key -%}text_{{ i }}{%- endcapture -%}
                {%- capture icon_key -%}icon_{{ i }}{%- endcapture -%}
                
                {%- if block.settings[title_key] != blank -%}
                  <div class="tech-card">
                    <div class="tech-card__icon">
                      {%- if block.settings[icon_key] != blank -%}
                        <img src="{{ block.settings[icon_key] | image_url: width: 100 }}" alt="{{ block.settings[title_key] }}">
                      {%- else -%}
                        <div class="tech-card__dot"></div>
                      {%- endif -%}
                    </div>
                    <div class="tech-card__content">
                      <h3>{{ block.settings[title_key] }}</h3>
                      <p>{{ block.settings[text_key] }}</p>
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </section>

      {%- when 'split_row' -%}
        <section class="tech-split {% if block.settings.alternate %}tech-split--alternate{% endif %}" {{ block.shopify_attributes }}>
          <div class="page-width">
            <div class="tech-split__row {% if block.settings.layout == 'media_right' %}tech-split__row--reverse{% endif %}">
              <div class="tech-split__media">
                {%- if block.settings.media_video != blank -%}
                   {{ block.settings.media_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, preload: 'auto', class: 'tech-split__video' }}
                {%- elsif block.settings.media_image != blank -%}
                   <img src="{{ block.settings.media_image | image_url: width: 1200 }}" alt="{{ block.settings.heading }}" class="tech-split__image">
                {%- else -%}
                   <div class="tech-placeholder-box"></div>
                {%- endif -%}
              </div>
              <div class="tech-split__content">
                {%- if block.settings.badge != blank -%}
                  <span class="tech-split__badge">{{ block.settings.badge }}</span>
                {%- endif -%}
                <h2 class="tech-split__heading">{{ block.settings.heading | default: "Built for endurance." }}</h2>
                <div class="tech-split__text">
                  {{ block.settings.text | default: "<p>Crafted from aerospace-grade titanium with a diamond-like carbon coating.</p>" }}
                </div>
              </div>
            </div>
          </div>
        </section>

      {%- when 'gallery' -%}
        <section class="tech-gallery" {{ block.shopify_attributes }}>
          <div class="page-width">
            {%- if block.settings.heading != blank -%}
              <div class="tech-gallery__header">
                <h2>{{ block.settings.heading }}</h2>
              </div>
            {%- endif -%}
             <div class="tech-gallery__grid">
                {%- for i in (1..3) -%}
                  {%- capture img_key -%}image_{{ i }}{%- endcapture -%}
                  {%- capture cap_key -%}caption_{{ i }}{%- endcapture -%}
                  <div class="tech-gallery__item">
                    {%- if block.settings[img_key] != blank -%}
                      <img src="{{ block.settings[img_key] | image_url: width: 1200 }}" alt="{{ block.settings[cap_key] | default: '' }}">
                    {%- else -%}
                      <div class="tech-placeholder-box"></div>
                    {%- endif -%}
                    {%- if block.settings[cap_key] != blank -%}
                      <p class="tech-gallery__caption">{{ block.settings[cap_key] }}</p>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
             </div>
          </div>
        </section>

      {%- when 'final_cta' -%}
        <section class="tech-cta" {{ block.shopify_attributes }}>
          <div class="page-width">
            <div class="tech-cta__inner">
              <h2 class="tech-cta__heading">{{ block.settings.heading | default: "The future is at your fingertips." }}</h2>
              <p class="tech-cta__text">{{ block.settings.text | default: "Experience the most advanced wearable technology ever engineered." }}</p>
              {%- if block.settings.link_text != blank -%}
                <div class="tech-cta__buttons">
                  <a href="{{ block.settings.link | default: '/collections/all' }}" class="btn btn--primary">
                    {{ block.settings.link_text }}
                  </a>
                </div>
              {%- endif -%}
            </div>
          </div>
        </section>

    {%- endcase -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Technology Page Content",
  "blocks": [
    {
      "type": "tech_hero",
      "name": "Hero Section",
      "limit": 1,
      "settings": [
        { "type": "video", "id": "background_video_hosted", "label": "Background Video" },
        { "type": "image_picker", "id": "image", "label": "Background Image" },
        { "type": "text", "id": "badge", "label": "Badge Text", "default": "THE INNOVATION" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Inside AURARING" },
        { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Clinical-grade sensor technology, miniaturized into a seamless titanium form factor." }
      ]
    },
    {
      "type": "intro",
      "name": "Intro Text",
      "settings": [
        { "type": "richtext", "id": "content", "label": "Intro Content" }
      ]
    },
    {
      "type": "feature_grid",
      "name": "Feature Grid",
      "settings": [
        { "type": "text", "id": "heading", "label": "Grid Heading", "default": "Precision Engineering" },
        { "type": "textarea", "id": "subheading", "label": "Grid Subheading" },
        { "type": "header", "content": "Card 1" },
        { "type": "text", "id": "title_1", "label": "Title 1" },
        { "type": "textarea", "id": "text_1", "label": "Text 1" },
        { "type": "image_picker", "id": "icon_1", "label": "Icon 1" },
        { "type": "header", "content": "Card 2" },
        { "type": "text", "id": "title_2", "label": "Title 2" },
        { "type": "textarea", "id": "text_2", "label": "Text 2" },
        { "type": "image_picker", "id": "icon_2", "label": "Icon 2" },
        { "type": "header", "content": "Card 3" },
        { "type": "text", "id": "title_3", "label": "Title 3" },
        { "type": "textarea", "id": "text_3", "label": "Text 3" },
        { "type": "image_picker", "id": "icon_3", "label": "Icon 3" },
        { "type": "header", "content": "Card 4" },
        { "type": "text", "id": "title_4", "label": "Title 4" },
        { "type": "textarea", "id": "text_4", "label": "Text 4" },
        { "type": "image_picker", "id": "icon_4", "label": "Icon 4" },
        { "type": "header", "content": "Card 5" },
        { "type": "text", "id": "title_5", "label": "Title 5" },
        { "type": "textarea", "id": "text_5", "label": "Text 5" },
        { "type": "image_picker", "id": "icon_5", "label": "Icon 5" },
        { "type": "header", "content": "Card 6" },
        { "type": "text", "id": "title_6", "label": "Title 6" },
        { "type": "textarea", "id": "text_6", "label": "Text 6" },
        { "type": "image_picker", "id": "icon_6", "label": "Icon 6" }
      ]
    },
    {
      "type": "split_row",
      "name": "Split Media Row",
      "settings": [
        { "type": "select", "id": "layout", "label": "Layout", "options": [
            { "value": "media_left", "label": "Media Left" },
            { "value": "media_right", "label": "Media Right" }
          ], "default": "media_left" },
        { "type": "checkbox", "id": "alternate", "label": "Alternate Background", "default": false },
        { "type": "text", "id": "badge", "label": "Badge" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Built for endurance." },
        { "type": "richtext", "id": "text", "label": "Description" },
        { "type": "image_picker", "id": "media_image", "label": "Image" },
        { "type": "video", "id": "media_video", "label": "Video" }
      ]
    },
    {
      "type": "gallery",
      "name": "Media Gallery",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Gallery Heading" },
        { "type": "image_picker", "id": "image_1", "label": "Image 1" },
        { "type": "text", "id": "caption_1", "label": "Caption 1" },
        { "type": "image_picker", "id": "image_2", "label": "Image 2" },
        { "type": "text", "id": "caption_2", "label": "Caption 2" },
        { "type": "image_picker", "id": "image_3", "label": "Image 3" },
        { "type": "text", "id": "caption_3", "label": "Caption 3" }
      ]
    },
    {
      "type": "final_cta",
      "name": "Final CTA",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "The future is at your fingertips." },
        { "type": "textarea", "id": "text", "label": "Subheading", "default": "Experience the most advanced wearable technology ever engineered." },
        { "type": "text", "id": "link_text", "label": "Button Text", "default": "Shop AURARING" },
        { "type": "url", "id": "link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Technology Page",
      "blocks": [
        { "type": "tech_hero" },
        { "type": "intro" },
        { "type": "feature_grid" },
        { "type": "split_row" },
        { "type": "final_cta" }
      ]
    }
  ]
}
{% endschema %}

