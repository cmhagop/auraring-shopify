<section class="product-education section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- comment -%} GUARANTEED VISIBLE FALLBACK AS REQUESTED {%- endcomment -%}
    <div style="background: #111; border: 1px solid rgba(255,255,255,0.1); padding: 40px; border-radius: 16px; margin-bottom: 40px; text-align: center;">
      <h2 style="color: #fff; margin-bottom: 8px;">Product Education</h2>
      <p style="color: #aaa; margin: 0;">
        If you can see this, the section was successfully mounted into the Shopify template.
      </p>
    </div>

    <div class="education__header text-center">
      {%- if section.settings.heading != blank -%}
        <h2 class="education__title">{{ section.settings.heading }}</h2>
      {%- else -%}
        <h2 class="education__title">Everything you need to know.</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="education__subtext">{{ section.settings.subheading }}</p>
      {%- else -%}
        <p class="education__subtext">Simple setup. Invisible tracking. Incredible insights.</p>
      {%- endif -%}
    </div>

    <div class="education__grid{% if section.settings.layout == 'media_first' %} education__grid--reverse{% endif %}">
      {%- comment -%} Info Column {%- endcomment -%}
      <div class="education__info">
        {%- for block in section.blocks -%}
          {%- if block.type == 'info_card' -%}
            <div class="education__card" {{ block.shopify_attributes }}>
              <h3 class="education__card-title">{{ block.settings.title }}</h3>
              <div class="education__card-text">{{ block.settings.text }}</div>

              {%- if block.settings.show_list -%}
                <ul class="education__list">
                  {%- if block.settings.list_item_1 != blank -%}
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" class="check-icon">
                        <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {{ block.settings.list_item_1 }}
                    </li>
                  {%- endif -%}
                  {%- if block.settings.list_item_2 != blank -%}
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" class="check-icon">
                        <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {{ block.settings.list_item_2 }}
                    </li>
                  {%- endif -%}
                  {%- if block.settings.list_item_3 != blank -%}
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" class="check-icon">
                        <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {{ block.settings.list_item_3 }}
                    </li>
                  {%- endif -%}
                  {%- if block.settings.list_item_4 != blank -%}
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" class="check-icon">
                        <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {{ block.settings.list_item_4 }}
                    </li>
                  {%- endif -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Media Column {%- endcomment -%}
      <div class="education__media">
        {%- for block in section.blocks -%}
          {%- if block.type == 'media_image' -%}
            <div class="education__media-item" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  width="800"
                  height="auto"
                  loading="lazy"
                >
              {%- else -%}
                <div style="width: 100%; height: 100%; background: #222; display: flex; align-items: center; justify-content: center; color: #666; font-size: 0.9rem;">
                  No Image Selected
                </div>
              {%- endif -%}
            </div>
          {%- elsif block.type == 'media_video' -%}
            <div class="education__media-item education__media-item--video" {{ block.shopify_attributes }}>
              {%- if block.settings.video != blank -%}
                {{
                  block.settings.video
                  | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '800x'
                }}
              {%- else -%}
                <div style="width: 100%; height: 100%; background: #222; display: flex; align-items: center; justify-content: center; color: #666; font-size: 0.9rem;">
                  No Video Selected
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Education",
  "tag": "section",
  "class": "section-product-education",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everything you need to know."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Simple setup. Invisible tracking. Incredible insights."
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop Layout",
      "options": [
        { "value": "text_first", "label": "Text First" },
        { "value": "media_first", "label": "Media First" }
      ],
      "default": "text_first"
    }
  ],
  "blocks": [
    {
      "type": "info_card",
      "name": "Info Card",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "What's in the Box"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description text",
          "default": "<p>Your ring comes with everything you need for 24/7 tracking.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_list",
          "label": "Show checklist item rows",
          "default": true
        },
        { "type": "text", "id": "list_item_1", "label": "List Item 1", "default": "AURARING Titanium Ring" },
        { "type": "text", "id": "list_item_2", "label": "List Item 2", "default": "Magnetic Charging Dock" },
        { "type": "text", "id": "list_item_3", "label": "List Item 3", "default": "USB-C to USB-A Cable" },
        { "type": "text", "id": "list_item_4", "label": "List Item 4", "default": "Quick Start Guide" }
      ]
    },
    {
      "type": "media_image",
      "name": "Media: Image",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "media_video",
      "name": "Media: Video",
      "limit": 2,
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-hosted Video"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Education",
      "blocks": [
        { "type": "info_card", "settings": { "title": "What's in the Box" } },
        {
          "type": "info_card",
          "settings": {
            "title": "How to Use It",
            "text": "<p>Slide it on your index, middle, or ring finger. The ring seamlessly tracks your body metrics automatically—no buttons to push or watches to scroll.</p>",
            "show_list": false
          }
        },
        { "type": "media_image" },
        { "type": "media_video" }
      ]
    }
  ]
}
{% endschema %}
