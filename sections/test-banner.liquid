<section class="test-banner" data-section-id="{{ section.id }}">
  <div class="test-banner__media">
    {%- if section.settings.video != blank -%}
      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          playsinline: true,
          controls: false,
          class: 'test-banner__video'
      }}
    {%- elsif section.settings.video_url != blank -%}
      {%- if section.settings.video_url.type == 'youtube' -%}
        <iframe
          src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ section.settings.video_url.id }}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
          class="test-banner__video test-banner__video--iframe"
          allow="autoplay; encrypted-media"
          allowfullscreen
          loading="lazy"
          title="{{ section.settings.heading | escape }}"
        ></iframe>
      {%- elsif section.settings.video_url.type == 'vimeo' -%}
        <iframe
          src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1&muted=1&loop=1&background=1&playsinline=1"
          class="test-banner__video test-banner__video--iframe"
          allow="autoplay; encrypted-media"
          allowfullscreen
          loading="lazy"
          title="{{ section.settings.heading | escape }}"
        ></iframe>
      {%- endif -%}
    {%- elsif section.settings.fallback_image != blank -%}
      <img
        src="{{ section.settings.fallback_image | image_url: width: 1920 }}"
        alt="{{ section.settings.heading | escape }}"
        class="test-banner__video"
        loading="lazy"
      >
    {%- else -%}
      <div class="test-banner__video test-banner__video--placeholder"></div>
    {%- endif -%}

    {%- comment -%} === Edge-fade overlays === {%- endcomment -%}
    <div class="test-banner__fade test-banner__fade--top"></div>
    <div class="test-banner__fade test-banner__fade--bottom"></div>
    <div class="test-banner__fade test-banner__fade--left"></div>
    <div class="test-banner__fade test-banner__fade--right"></div>
  </div>

  {%- comment -%} === Content overlay === {%- endcomment -%}
  <div class="test-banner__content">
    <div class="page-width">
      {%- if section.settings.badge_text != blank -%}
        <div class="test-banner__badge">
          <span class="badge">{{ section.settings.badge_text }}</span>
        </div>
      {%- endif -%}

      <h2 class="test-banner__heading">{{ section.settings.heading }}</h2>

      {%- if section.settings.subheading != blank -%}
        <p class="test-banner__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.cta_text != blank or section.settings.cta_text_2 != blank -%}
        <div class="test-banner__cta-group">
          {%- if section.settings.cta_text != blank -%}
            {%- assign btn_url = section.settings.cta_product.url | default: section.settings.cta_link -%}
            {%- render 'button', label: section.settings.cta_text, url: btn_url, style: 'accent', size: 'lg' -%}
          {%- endif -%}

          {%- if section.settings.cta_text_2 != blank -%}
            {%- assign btn_url_2 = section.settings.cta_product_2.url | default: section.settings.cta_link_2 -%}
            {%- render 'button',
              label: section.settings.cta_text_2,
              url: btn_url_2,
              style: 'ghost',
              size: 'lg',
              class: 'test-banner__btn-ghost'
            -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  /* ================================================================
     TEST BANNER — Cinematic single-product video section
     ================================================================ */
  .test-banner {
    position: relative;
    width: 100%;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 0;
    background-color: var(--color-bg, #000);
  }

  /* --- Media layer ------------------------------------------------ */
  .test-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .test-banner__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .test-banner__video--placeholder {
    background-color: #111;
  }

  .test-banner__video--iframe {
    border: 0;
    pointer-events: none;
    /* Scale the iframe up to avoid letterboxing */
    position: absolute;
    top: 50%;
    left: 50%;
    width: 120%;
    height: 120%;
    transform: translate(-50%, -50%);
  }

  /* --- Edge-fade gradient overlays -------------------------------- */
  .test-banner__fade {
    position: absolute;
    z-index: 1;
    pointer-events: none;
  }

  .test-banner__fade--top {
    top: 0;
    left: 0;
    right: 0;
    height: 30%;
    background: linear-gradient(180deg, var(--color-bg) 0%, rgba(10, 10, 10, 0.7) 40%, transparent 100%);
  }

  .test-banner__fade--bottom {
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(0deg, var(--color-bg) 0%, rgba(10, 10, 10, 0.75) 35%, transparent 100%);
  }

  .test-banner__fade--left {
    top: 0;
    bottom: 0;
    left: 0;
    width: 15%;
    background: linear-gradient(90deg, var(--color-bg) 0%, transparent 100%);
  }

  .test-banner__fade--right {
    top: 0;
    bottom: 0;
    right: 0;
    width: 15%;
    background: linear-gradient(270deg, var(--color-bg) 0%, transparent 100%);
  }

  /* --- Content overlay -------------------------------------------- */
  .test-banner__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 80px 20px;
    width: 100%;
  }

  .test-banner__badge {
    margin-bottom: 24px;
  }

  .test-banner__heading {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-text);
    text-shadow: 0 4px 60px rgba(0, 0, 0, 0.5);
    margin-bottom: 20px;
  }

  .test-banner__subheading {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: rgba(240, 240, 240, 0.65);
    line-height: 1.7;
    max-width: 520px;
    margin-inline: auto;
    margin-bottom: 40px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
  }

  .test-banner__cta-group {
    margin-top: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Extends the button snippet with a specific ghost style if the snippet doesn't natively support it perfectly */
  .test-banner__btn-ghost {
    background: transparent !important;
    border: 1px solid rgba(255, 255, 255, 0.3) !important;
    color: #fff !important;
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }

  .test-banner__btn-ghost:hover {
    border-color: #fff !important;
    background: rgba(255, 255, 255, 0.05) !important;
  }

  /* --- Responsive ------------------------------------------------- */
  @media (max-width: 749px) {
    .test-banner {
      min-height: 70vh;
    }

    .test-banner__content {
      padding: 60px 16px;
    }

    .test-banner__fade--top {
      height: 25%;
    }

    .test-banner__fade--bottom {
      height: 35%;
    }

    .test-banner__fade--left,
    .test-banner__fade--right {
      width: 8%;
    }

    .test-banner__heading {
      font-size: clamp(2rem, 10vw, 3.2rem);
    }

    .test-banner__cta-group {
      flex-direction: column;
      gap: 12px;
      width: 100%;
    }

    .test-banner__cta-group .button {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "cinematic-product-banner",
  "tag": "section",
  "class": "test-banner-section",
  "settings": [
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Featured" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Auraring Tungsten" },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Forged from aerospace-grade tungsten carbide. Indestructible. Timeless. Unmistakably premium."
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify Video",
      "info": "Upload a video in Settings > Files, then select it here. It will autoplay muted."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "YouTube / Vimeo URL (fallback)",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback image"
    },
    {
      "type": "header",
      "content": "Primary call to action"
    },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Shop Tungsten" },
    { "type": "product", "id": "cta_product", "label": "Button product" },
    { "type": "url", "id": "cta_link", "label": "Button link (fallback)" },
    {
      "type": "header",
      "content": "Secondary call to action"
    },
    { "type": "text", "id": "cta_text_2", "label": "Secondary button text", "default": "All Products" },
    { "type": "product", "id": "cta_product_2", "label": "Secondary button product" },
    { "type": "url", "id": "cta_link_2", "label": "Secondary button link (fallback)" }
  ],
  "presets": [
    {
      "name": "Cinematic Product Banner"
    }
  ]
}
{% endschema %}
