<section class="hero hero--banner" id="hero" data-section-id="{{ section.id }}">
  <!-- Banner image layer -->
  <div class="hero__media">
    {%- if section.settings.banner_image -%}
      <img
        src="{{ section.settings.banner_image | image_url: width: 2400 }}"
        srcset="{{ section.settings.banner_image | image_url: width: 1200 }} 1200w, {{ section.settings.banner_image | image_url: width: 1800 }} 1800w, {{ section.settings.banner_image | image_url: width: 2400 }} 2400w"
        sizes="100vw"
        alt="{{ section.settings.banner_image.alt | default: section.settings.heading | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <img
        src="{{ 'hero-banner.png' | asset_url }}"
        alt="{{ section.settings.heading | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
  </div>

  <!-- Gradient overlays -->
  <div class="hero__overlay"></div>
  <div class="hero__orb hero__orb--1"></div>
  <div class="hero__orb hero__orb--2"></div>

  <!-- Text content -->
  <div class="page-width">
    <div class="hero__content reveal">
      {%- if section.settings.badge_text != blank -%}
        <div class="hero__badge">
          <span class="badge">{{ section.settings.badge_text }}</span>
        </div>
      {%- endif -%}
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p class="hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="hero__buttons">
        {%- if section.settings.button_primary_text != blank -%}
          {%- render 'button',
            label: section.settings.button_primary_text,
            url: section.settings.button_primary_link,
            style: 'primary',
            size: 'lg'
          -%}
        {%- endif -%}
        {%- if section.settings.button_secondary_text != blank -%}
          {%- render 'button',
            label: section.settings.button_secondary_text,
            url: section.settings.button_secondary_link,
            style: 'secondary',
            size: 'lg'
          -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    { "type": "image_picker", "id": "banner_image", "label": "Banner image" },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Next-Gen Wearable" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Precision health.<br>On your finger." },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Track sleep, heart rate, HRV, and blood oxygen with clinical-grade accuracy — all from a ring you never need to take off."
    },
    { "type": "text", "id": "button_primary_text", "label": "Primary button text", "default": "Shop Now" },
    { "type": "url", "id": "button_primary_link", "label": "Primary button link", "default": "" },
    { "type": "text", "id": "button_secondary_text", "label": "Secondary button text", "default": "Learn More" },
    { "type": "url", "id": "button_secondary_link", "label": "Secondary button link" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
